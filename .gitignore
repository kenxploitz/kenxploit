*.pyc
*.pyo
*.egg-info/
dist/
build/

# Node
node_modules/
bun.lock
bun.lockb

# OS files
.DS_Store
Thumbs.db
*.swp
*.swo
*~

# Environment
.env
.env.local
*.log

# Binary backup
*.backup-*

# Config with real API keys (template saja yang di-push)
config.local.json
opencode.local.json
